#include "Wiegand.h"

Wiegand* Wiegand::instance = nullptr;

Wiegand::Wiegand() {
    instance = this;
    _bitCount = 0;
    _code = 0;
    _lastBitTime = 0;
    _available = false;
    _lastCode = 0;
    _lastBitCount = 0;
}

void Wiegand::begin(uint8_t pinD0, uint8_t pinD1) {
    _pinD0 = pinD0;
    _pinD1 = pinD1;

    pinMode(_pinD0, INPUT_PULLUP);
    pinMode(_pinD1, INPUT_PULLUP);

    attach();
}

void Wiegand::attach() {
    attachInterrupt(digitalPinToInterrupt(_pinD0), data0ISR, FALLING);
    attachInterrupt(digitalPinToInterrupt(_pinD1), data1ISR, FALLING);
}

void Wiegand::detach() {
    detachInterrupt(digitalPinToInterrupt(_pinD0));
    detachInterrupt(digitalPinToInterrupt(_pinD1));
}

void IRAM_ATTR Wiegand::data0ISR() {
    instance->handleData(0);
}

void IRAM_ATTR Wiegand::data1ISR() {
    instance->handleData(1);
}

void IRAM_ATTR Wiegand::handleData(uint8_t data) {
    unsigned long now = micros();
    // Glitch filter: Wiegand pulses are at least 1ms apart; ignore if < 200µs since last bit
    if (instance->_bitCount > 0 && (now - instance->_lastBitTime) < 200) {
        return;
    }
    if (instance->_bitCount < 32) {
        instance->_code <<= 1;
        if (data) {
            instance->_code |= 1;
        }
    }
    instance->_bitCount += 1;
    instance->_lastBitTime = now;
}

void Wiegand::loop() {
    noInterrupts();
    uint8_t count = _bitCount;
    unsigned long lastTime = _lastBitTime;
    interrupts();

    if (count > 0 && (micros() - lastTime) > 50000) {
        processCode();
    }
}

void Wiegand::processCode() {
    noInterrupts();
    uint32_t code = _code;
    uint8_t count = _bitCount;
    _code = 0;
    _bitCount = 0;
    interrupts();

    if (count >= 4) { // Minimum valid length
        if (count == 26) {
            // Wiegand-26 parity check
            // Bit 25: even parity over bits 24-13
            // Bit  0: odd  parity over bits 12-1
            uint8_t evenBits = __builtin_popcount((code >> 13) & 0xFFF);
            uint8_t oddBits  = __builtin_popcount((code >>  1) & 0xFFF);
            if ((evenBits % 2) != ((code >> 25) & 1)) return; // even parity fail
            if ((oddBits  % 2) == (code & 1))         return; // odd  parity fail
        }
        _lastCode = code;
        _lastBitCount = count;
        _available = true;
    }
}

bool Wiegand::isAvailable() {
    if (_available) {
        _available = false;
        return true;
    }
    return false;
}

uint32_t Wiegand::getCode() {
    return _lastCode;
}

uint8_t Wiegand::getBitCount() {
    return _lastBitCount;
}
